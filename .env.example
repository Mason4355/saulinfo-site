FLASK_ENV=production
SAULINFO_SECRET_KEY=change-me
SAULINFO_HOST=0.0.0.0
SAULINFO_PORT=8080

# Public domain
PUBLIC_BASE_URL=https://www.saulinfo.ru
ALLOW_SELF_REGISTRATION=false

# Local email auth database
SAULINFO_DATA_DIR=/data
SAULINFO_AUTH_DB_PATH=/data/saulinfo_auth.db

# Integration with existing shop-update data
SHOP_UPDATE_DATA_DIR=/root/shop-update/data
SHOP_UPDATE_DB_PATH=/integrations/shop-update/users.db
SHOP_UPDATE_PANEL_URL=https://panel.saulinfo.ru
